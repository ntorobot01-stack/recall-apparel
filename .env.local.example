# ─────────────────────────────────────────────────────────────────────
# Recall Apparel — variables de entorno
# ─────────────────────────────────────────────────────────────────────
# Copiá este archivo como `.env.local` (gitignored) y rellená los valores.
# .env.local NUNCA debe commitearse al repo.
# ─────────────────────────────────────────────────────────────────────

# Frontend (Vite — expuestas al cliente, OK que sean públicas)
# Sólo las claves "publishable" / "anon" deben llevar el prefijo VITE_.
VITE_SUPABASE_URL=https://hfhljqtithkcdgkujery.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Sync worker (Node, server-side — NUNCA al frontend, NUNCA a GitHub)
# La SECRET_KEY tiene privilegios de service_role: bypassa RLS y puede
# escribir/borrar cualquier tabla. Si se filtra al cliente, alguien
# puede hacer DELETE FROM verified_offers desde el browser.
SUPABASE_URL=https://hfhljqtithkcdgkujery.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Sync worker — parámetros operativos (Sesión 5)
SYNC_FREQUENCY_HOURS=6
MIN_DISCOUNT_PERCENT=20
